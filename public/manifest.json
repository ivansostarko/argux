{
    "name": "ARGUX Tactical Intelligence Platform",
    "short_name": "ARGUX",
    "description": "Tactical intelligence and geospatial surveillance platform",
    "start_url": "/map",
    "display": "standalone",
    "orientation": "any",
    "background_color": "#080a0f",
    "theme_color": "#1d6fef",
    "categories": ["security", "productivity", "utilities"],
    "icons": [
        { "src": "/icons/icon-192.svg", "sizes": "192x192", "type": "image/svg+xml", "purpose": "any maskable" },
        { "src": "/icons/icon-512.svg", "sizes": "512x512", "type": "image/svg+xml", "purpose": "any maskable" }
    ],
    "screenshots": [],
    "shortcuts": [
        { "name": "Tactical Map", "short_name": "Map", "url": "/map", "icons": [{ "src": "/icons/icon-192.svg", "sizes": "192x192" }] },
        { "name": "Persons", "short_name": "Persons", "url": "/persons" },
        { "name": "Notifications", "short_name": "Alerts", "url": "/notifications" },
        { "name": "AI Assistant", "short_name": "AI", "url": "/chat" }
    ],
    "share_target": {
        "action": "/share-target",
        "method": "POST",
        "enctype": "multipart/form-data",
        "params": {
            "title": "title",
            "text": "text",
            "url": "url",
            "files": [{ "name": "media", "accept": ["image/*", "video/*", "application/pdf"] }]
        }
    },
    "protocol_handlers": [
        { "protocol": "web+argux", "url": "/protocol?q=%s" }
    ],
    "related_applications": [],
    "prefer_related_applications": false
}
