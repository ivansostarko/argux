{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "ARGUX",
  "version": "0.24.2",
  "identifier": "com.argux.tactical",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:8000",
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "title": "ARGUX — Tactical Intelligence Platform",
    "windows": [
      {
        "label": "main",
        "title": "ARGUX — Tactical Intelligence Platform",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true,
        "focus": true,
        "maximized": false
      }
    ],
    "security": {
      "csp": "default-src * 'self' 'unsafe-inline' 'unsafe-eval' data: blob: ws: wss:; img-src * 'self' data: blob: https: http:; connect-src * 'self' https: http: ws: wss: data: blob:; script-src * 'self' 'unsafe-inline' 'unsafe-eval' blob:; style-src * 'self' 'unsafe-inline'; font-src * 'self' data: https: http:; media-src * 'self' blob: https: http: data:; worker-src * 'self' blob:; frame-src * 'self' https: http: blob: data:; child-src * 'self' blob:",
      "dangerousRemoteDomainIpcAccess": [
        {
          "scheme": "https",
          "domain": "app.argux.cloud",
          "windows": ["main"],
          "plugins": ["shell", "notification", "dialog", "clipboard-manager"]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "languages": ["English", "Croatian"],
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "installMode": "both"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": [],
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0"
        ],
        "section": "utils"
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3"
        ]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "iOS": {
      "developmentTeam": ""
    },
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "notification": {
      "all": true
    },
    "clipboard-manager": {
      "all": true
    }
  }
}
