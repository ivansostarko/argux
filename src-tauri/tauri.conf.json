{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "ARGUX",
  "version": "0.25.95",
  "identifier": "com.argux.tactical",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:8000",
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ARGUX \u2014 Tactical Intelligence Platform",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true,
        "focus": true,
        "maximized": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com; style-src 'self' 'unsafe-inline' https://unpkg.com; img-src 'self' data: blob: https: http:; connect-src 'self' https: http: ws: wss:; font-src 'self' data: https:; media-src 'self' blob: https: http:; worker-src 'self' blob:; frame-src 'self' https:; child-src 'self' blob:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "languages": [
          "English",
          "Croatian"
        ],
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "installMode": "both"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": [],
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0"
        ],
        "section": "utils"
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3"
        ]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "iOS": {
      "developmentTeam": ""
    },
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "notification": {
      "all": true
    },
    "clipboard-manager": {
      "all": true
    },
    "updater": {
      "endpoints": [
        "https://releases.argux.app/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "",
      "windows": {
        "installMode": "passive"
      }
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "argux"
        ]
      },
      "mobile": [
        {
          "host": "app.argux.cloud",
          "pathPrefix": "/"
        }
      ]
    },
    "cli": {
      "args": [
        {
          "name": "verbose",
          "short": "v",
          "description": "Enable verbose logging",
          "takesValue": false
        },
        {
          "name": "config",
          "short": "c",
          "description": "Path to config file",
          "takesValue": true
        },
        {
          "name": "minimized",
          "description": "Start minimized to tray",
          "takesValue": false
        },
        {
          "name": "url",
          "description": "Open specific URL on startup",
          "takesValue": true
        }
      ],
      "description": "ARGUX Tactical Intelligence Platform",
      "longDescription": "ARGUX \u2014 On-premise tactical intelligence and geospatial surveillance platform."
    },
    "autostart": {
      "args": [
        "--minimized"
      ]
    },
    "store": {},
    "log": {
      "level": "info"
    }
  }
}