# ============================================================
# argux Server 1 — Application Server Environment
# ============================================================
# Copy to .env and fill in all values before starting.
# NEVER commit .env to version control.
# ============================================================

# ── General ──────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=argux-app
argux_DOMAIN=argux.local
argux_ENV=production
TZ=UTC

# ── Laravel / PHP ────────────────────────────────────────────
APP_NAME=argux
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_PHP_ARTISAN_KEY_GENERATE
APP_DEBUG=false
APP_URL=https://argux.local
APP_PORT=8000

# Laravel Octane
OCTANE_SERVER=swoole
OCTANE_WORKERS=16
OCTANE_TASK_WORKERS=8
OCTANE_MAX_REQUESTS=1000

# Laravel Reverb (WebSocket)
REVERB_APP_ID=argux-reverb
REVERB_APP_KEY=CHANGE_ME_REVERB_KEY
REVERB_APP_SECRET=CHANGE_ME_REVERB_SECRET
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=https

# Laravel Sanctum
SANCTUM_STATEFUL_DOMAINS=argux.local
SESSION_DOMAIN=.argux.local

# Laravel Horizon
HORIZON_PREFIX=argux_horizon:

# ── Database Connections (remote — Server 2) ─────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres.argux.local
DB_PORT=5432
DB_DATABASE=argux
DB_USERNAME=argux_app
DB_PASSWORD=CHANGE_ME_PG_PASSWORD

MYSQL_HOST=mysql.argux.local
MYSQL_PORT=3306
MYSQL_DATABASE=argux_logs
MYSQL_USERNAME=argux_app
MYSQL_PASSWORD=CHANGE_ME_MYSQL_PASSWORD

# ── Redis 8 Cluster ─────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_CLUSTER=redis
REDIS_HOST=redis-node-1
REDIS_PORT=6379

# ── Kafka (remote — Server 2) ───────────────────────────────
KAFKA_BROKERS=kafka-1.argux.local:9092,kafka-2.argux.local:9093,kafka-3.argux.local:9094

# ── Typesense (remote — Server 2) ───────────────────────────
TYPESENSE_API_KEY=CHANGE_ME_TYPESENSE_KEY
TYPESENSE_HOST=typesense-1.argux.local
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http

# ── ClickHouse (remote — Server 2) ──────────────────────────
CLICKHOUSE_HOST=clickhouse.argux.local
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=argux
CLICKHOUSE_USERNAME=argux_app
CLICKHOUSE_PASSWORD=CHANGE_ME_CH_PASSWORD

# ── MinIO (remote — Server 4) ───────────────────────────────
MINIO_ENDPOINT=minio.argux.local:9000
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
MINIO_BUCKET=argux-media
MINIO_REGION=us-east-1

# ── Qdrant (remote — Server 4) ──────────────────────────────
QDRANT_HOST=qdrant.argux.local
QDRANT_PORT=6333
QDRANT_API_KEY=CHANGE_ME_QDRANT_KEY

# ── AI Service (remote — Server 3) ──────────────────────────
AI_SERVICE_URL=http://fastapi.argux.local:8001
OLLAMA_HOST=http://ollama.argux.local:11434

# ── Nginx ────────────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=4096

# ── step-ca (Private CA) ────────────────────────────────────
STEP_CA_PASSWORD=CHANGE_ME_STEP_CA_PASSWORD
STEP_CA_PROVISIONER_PASSWORD=CHANGE_ME_STEP_PROVISIONER_PASSWORD

# ── Infisical ────────────────────────────────────────────────
INFISICAL_TOKEN=CHANGE_ME_INFISICAL_TOKEN
INFISICAL_SITE_URL=http://infisical:8060

# ── Prometheus ───────────────────────────────────────────────
PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_RETENTION_SIZE=50GB

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
GRAFANA_PORT=3000

# ── Loki ─────────────────────────────────────────────────────
LOKI_RETENTION_PERIOD=720h

# ── GlitchTip ────────────────────────────────────────────────
GLITCHTIP_DSN=http://glitchtip.argux.local:5057
SENTRY_DSN=http://key@glitchtip.argux.local:5057/1

# ── MediaMTX ─────────────────────────────────────────────────
MEDIAMTX_RTSP_PORT=8554
MEDIAMTX_HLS_PORT=8888
MEDIAMTX_WEBRTC_PORT=8889
MEDIAMTX_API_PORT=9997
MEDIAMTX_METRICS_PORT=9998

# ── WireGuard VPN ────────────────────────────────────────────
WG_SERVER_PORT=51820
WG_SERVER_PRIVATE_KEY=CHANGE_ME_WG_PRIVATE_KEY
WG_SERVER_ADDRESS=10.10.0.1/24
WG_PEERS=3

# ── CrowdSec ────────────────────────────────────────────────
CROWDSEC_AGENT_PASSWORD=CHANGE_ME_CROWDSEC_PASSWORD
CROWDSEC_BOUNCER_KEY=CHANGE_ME_BOUNCER_KEY

# ── Logging ──────────────────────────────────────────────────
LOG_DRIVER=json-file
LOG_MAX_SIZE=50m
LOG_MAX_FILE=5
