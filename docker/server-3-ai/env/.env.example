# ============================================================
# argux Server 3 — AI Server Environment
# ============================================================

COMPOSE_PROJECT_NAME=argux-ai
TZ=UTC

# ── Ollama ───────────────────────────────────────────────────
OLLAMA_HOST=0.0.0.0:11434
OLLAMA_MODELS=/models
OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_LOADED_MODELS=3

# ── FastAPI AI Microservice ──────────────────────────────────
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8001
FASTAPI_WORKERS=4

# ── GPU Configuration ────────────────────────────────────────
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# ── Connections to Other Servers ─────────────────────────────
KAFKA_BROKERS=kafka-1.argux.local:9092,kafka-2.argux.local:9093,kafka-3.argux.local:9094
REDIS_URL=redis://redis-node-1.argux.local:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

POSTGRES_HOST=postgres.argux.local
POSTGRES_PORT=5432
POSTGRES_DB=argux
POSTGRES_USER=argux_app
POSTGRES_PASSWORD=CHANGE_ME_PG_PASSWORD

CLICKHOUSE_HOST=clickhouse.argux.local
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=argux
CLICKHOUSE_USER=argux_app
CLICKHOUSE_PASSWORD=CHANGE_ME_CH_PASSWORD

MINIO_ENDPOINT=minio.argux.local:9000
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET

QDRANT_HOST=qdrant.argux.local
QDRANT_PORT=6333
QDRANT_API_KEY=CHANGE_ME_QDRANT_KEY

# ── Model Paths ──────────────────────────────────────────────
INSIGHTFACE_MODEL=buffalo_l
YOLO_MODEL_PATH=/models/yolov11n-plates.pt
PADDLEOCR_LANG=en
NLLB_MODEL=facebook/nllb-200-distilled-600M
SPEECHBRAIN_MODEL=speechbrain/spkrec-ecapa-voxceleb

# ── Logging ──────────────────────────────────────────────────
LOG_MAX_SIZE=50m
LOG_MAX_FILE=5
