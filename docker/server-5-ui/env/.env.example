# ============================================================
# argux Server 5 — Management UI Server Environment
# ============================================================
# All UIs accessible only via WireGuard VPN (10.10.0.0/24)
# ============================================================

COMPOSE_PROJECT_NAME=argux-ui
TZ=UTC

# ── pgAdmin 4 ────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@argux.local
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD
PGADMIN_LISTEN_PORT=5050

# ── phpMyAdmin ───────────────────────────────────────────────
PMA_HOST=mysql.argux.local
PMA_PORT=3306

# ── RedisInsight ─────────────────────────────────────────────
REDISINSIGHT_PORT=5053

# ── Kafka UI (Provectus) ────────────────────────────────────
KAFKA_CLUSTERS_0_NAME=argux-production
KAFKA_CLUSTERS_0_BOOTSTRAPSERVERS=kafka-1.argux.local:9092,kafka-2.argux.local:9093,kafka-3.argux.local:9094
KAFKA_CLUSTERS_0_SCHEMAREGISTRY=http://karapace.argux.local:8081

# ── GlitchTip ────────────────────────────────────────────────
GLITCHTIP_DOMAIN=http://glitchtip.argux.local:5057
SECRET_KEY=CHANGE_ME_GLITCHTIP_SECRET_KEY
DATABASE_URL=postgresql://argux_app:CHANGE_ME_PG_PASSWORD@postgres.argux.local:5432/glitchtip
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis-node-1.argux.local:6379/2
DEFAULT_FROM_EMAIL=noreply@argux.local
GLITCHTIP_MAX_EVENT_LIFE_DAYS=90
ENABLE_USER_REGISTRATION=false

# ── Infisical UI ─────────────────────────────────────────────
INFISICAL_SITE_URL=http://infisical.argux.local:8060

# ── Wazuh Dashboard ─────────────────────────────────────────
WAZUH_API_URL=https://wazuh-manager.argux.local
WAZUH_DASHBOARD_USERNAME=admin
WAZUH_DASHBOARD_PASSWORD=CHANGE_ME_WAZUH_PASSWORD

# ── Database Connections (for UI tools) ──────────────────────
POSTGRES_HOST=postgres.argux.local
POSTGRES_PORT=5432
MYSQL_HOST=mysql.argux.local
MYSQL_PORT=3306
CLICKHOUSE_HOST=clickhouse.argux.local
CLICKHOUSE_PORT=8123
REDIS_HOST=redis-node-1.argux.local
REDIS_PORT=6379

# ── Logging ──────────────────────────────────────────────────
LOG_MAX_SIZE=50m
LOG_MAX_FILE=5
