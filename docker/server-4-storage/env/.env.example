# ============================================================
# argux Server 4 — Storage Server Environment
# ============================================================

COMPOSE_PROJECT_NAME=argux-storage
TZ=UTC

# ── MinIO Distributed ────────────────────────────────────────
MINIO_ROOT_USER=argux-minio-admin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_ROOT_PASSWORD
MINIO_VOLUMES=/data{1...4}
MINIO_SERVER_URL=https://minio.argux.local:9000
MINIO_BROWSER_REDIRECT_URL=https://minio-console.argux.local:9001

# MinIO Prometheus
MINIO_PROMETHEUS_AUTH_TYPE=public

# ── Qdrant ───────────────────────────────────────────────────
QDRANT_API_KEY=CHANGE_ME_QDRANT_KEY
QDRANT_STORAGE_DIR=/qdrant/storage
QDRANT_SNAPSHOTS_DIR=/qdrant/snapshots

# ── Logging ──────────────────────────────────────────────────
LOG_MAX_SIZE=50m
LOG_MAX_FILE=5
