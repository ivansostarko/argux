# ============================================================
# argux Server 2 — Database & Messaging Server Environment
# ============================================================

COMPOSE_PROJECT_NAME=argux-dbmsg
TZ=UTC

# ── PostgreSQL 17 ────────────────────────────────────────────
POSTGRES_DB=argux
POSTGRES_USER=argux_app
POSTGRES_PASSWORD=CHANGE_ME_PG_PASSWORD
POSTGRES_MAX_CONNECTIONS=300
POSTGRES_SHARED_BUFFERS=16GB
POSTGRES_EFFECTIVE_CACHE_SIZE=48GB
POSTGRES_WORK_MEM=256MB
POSTGRES_MAINTENANCE_WORK_MEM=2GB

# ── MySQL 9.1 ────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_MYSQL_ROOT_PASSWORD
MYSQL_DATABASE=argux_logs
MYSQL_USER=argux_app
MYSQL_PASSWORD=CHANGE_ME_MYSQL_PASSWORD

# ── ClickHouse 25 ────────────────────────────────────────────
CLICKHOUSE_DB=argux
CLICKHOUSE_USER=argux_app
CLICKHOUSE_PASSWORD=CHANGE_ME_CH_PASSWORD
CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT=1

# ── Apache Kafka 4.0 (KRaft) ────────────────────────────────
KAFKA_CLUSTER_ID=CHANGE_ME_GENERATE_WITH_kafka-storage_random-uuid
KAFKA_HEAP_OPTS=-Xmx4G -Xms4G

# ── Karapace Schema Registry ────────────────────────────────
KARAPACE_HOST=0.0.0.0
KARAPACE_PORT=8081

# ── Typesense 28 ─────────────────────────────────────────────
TYPESENSE_API_KEY=CHANGE_ME_TYPESENSE_KEY
TYPESENSE_DATA_DIR=/data

# ── Logging ──────────────────────────────────────────────────
LOG_MAX_SIZE=50m
LOG_MAX_FILE=5
